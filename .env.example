# Stripe hosted checkout URL used directly by Buy buttons
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Optional: required only for advanced Stripe API operations
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
ACCESS_COOKIE_SECRET=replace-with-a-second-long-random-secret

# Discord OAuth app credentials
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret

# Optional bot + webhook validation settings
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_WEBHOOK_SECRET=optional_webhook_signature_secret
DISCORD_RECORDING_WEBHOOK_URL=http://localhost:3000/api/discord/webhook

# OpenAI
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini
